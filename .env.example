# Copy this file to .env for local testing.
# Vercel deployment: add the same names in Settings > Environment Variables.

# 1) Naver Cloud Platform Maps Application credentials
#    Screenshot labels:
#    - Client ID (X-NCP-APIGW-API-KEY-ID)     -> NAVER_CLOUD_MAPS_NCP_KEY_ID
#    - Client Secret (X-NCP-APIGW-API-KEY)    -> NAVER_CLOUD_MAPS_CLIENT_SECRET
#    The same Client ID is used for Web Dynamic Map SDK and Maps REST APIs.
NAVER_CLOUD_MAPS_NCP_KEY_ID=your_naver_cloud_maps_client_id_or_ncp_key_id
NAVER_CLOUD_MAPS_CLIENT_SECRET=your_naver_cloud_maps_client_secret

# Backward-compatible aliases also supported by the code:
# NAVER_MAP_NCP_KEY_ID=your_naver_cloud_web_dynamic_map_ncp_key_id
# NAVER_MAP_CLIENT_SECRET=your_naver_cloud_maps_client_secret

# 2) Naver Developers Search API credentials
#    Screenshot labels:
#    - Client ID       -> NAVER_DEVELOPERS_SEARCH_CLIENT_ID
#    - Client Secret   -> NAVER_DEVELOPERS_SEARCH_CLIENT_SECRET
#    Used for place/local search before converting the result to map coordinates.
NAVER_DEVELOPERS_SEARCH_CLIENT_ID=your_naver_developers_search_client_id
NAVER_DEVELOPERS_SEARCH_CLIENT_SECRET=your_naver_developers_search_client_secret

# Backward-compatible aliases also supported by the code:
# NAVER_SEARCH_CLIENT_ID=your_naver_developers_search_client_id
# NAVER_SEARCH_CLIENT_SECRET=your_naver_developers_search_client_secret
