# Copy this file to .env for local testing.
# Vercel deployment: add the same names in Settings > Environment Variables.

# Naver Cloud Platform Maps Application Client ID / ncpKeyId
NAVER_MAP_CLIENT_ID=your_naver_client_id

# Naver Cloud Platform Maps Application Client Secret
# Never paste this directly into index.html or browser JavaScript.
NAVER_MAP_CLIENT_SECRET=your_naver_client_secret
